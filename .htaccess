DirectoryIndex index.html
ErrorDocument 404 /404.html

RewriteEngine On

# 1. Redireciona solicitações index.html para a raiz (/)
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Redireciona solicitações externas com .html para a URL limpa (evita conteúdo duplicado)
RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 3. Reescreve internamente a URL limpa para o arquivo .html (se ele existir física e realmente)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]